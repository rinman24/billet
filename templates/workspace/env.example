# Copy into the repo as .devcontainer/.env.example, then on the VM copy that to the
# gitignored .devcontainer/.env (docker compose auto-loads it). The recommended
# zero-touch wiring is billet's host_bootstrap_cmd:
#
#   host_bootstrap_cmd = "cp -n .devcontainer/.env.example .devcontainer/.env"
#
# Point the container's sshd at the VM's existing authorized_keys so the operator's
# forwarded key is trusted (same key that opens the VM opens the container). Without
# this the tracked empty stub is mounted and sshd trusts no keys. Adjust the path if
# the Host's admin_user is not azureuser.
DEVBOX_AUTHORIZED_KEYS=/home/azureuser/.ssh/authorized_keys
