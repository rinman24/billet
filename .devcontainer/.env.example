# Copy to .devcontainer/.env on the VM (gitignored). docker compose auto-loads it.
#
# Point the container's sshd at the VM's existing authorized_keys so the operator's
# forwarded key is trusted (same key that opens the VM opens the container). Without this
# the tracked empty stub is mounted and sshd trusts no keys.
DEVBOX_AUTHORIZED_KEYS=/home/azureuser/.ssh/authorized_keys
